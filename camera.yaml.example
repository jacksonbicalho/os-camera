debug: false                         # env: DEBUG
timezone: America/Sao_Paulo          # env: TIMEZONE — fuso horário da instalação (padrão: UTC)

log:
  output: stdout     # stdout | file — env: LOG_OUTPUT
  path:              # diretório quando output: file — env: LOG_PATH

server:
  port: 8080                        # env: SERVER_PORT
  segments_path: /tmp/hls           # env: SEGMENTS_PATH
  username: master                  # env: SERVER_USERNAME
  password: ""                      # env: SERVER_PASSWORD

storage:
  path: /data/recordings     # env: STORAGE_PATH
  retention_days: 30         # apaga gravações mais antigas que N dias (0 = desabilitado)
  max_size_gb: 10            # tamanho máximo do diretório de gravações em GB (0 = desabilitado)
  warn_percent: 70           # avisa quando uso atingir X% do max_size_gb (ex: 70% de 10 GB = 7 GB)

defaults:
  chunk_duration: 5m         # env: CHUNK_DURATION
  reconnect_interval: 10s    # env: RECONNECT_INTERVAL

motion:
  enabled: false      # habilita detecção de movimento por câmera
  threshold: 0.02     # fração mínima de pixels alterados para registrar evento (0.0–1.0)
  fps: 2              # frames por segundo capturados para análise de movimento

cameras:
  - id: entrada
    rtsp_url: rtsp://192.168.1.10:554/stream
    # Configurações de stream (opcionais — detectadas via ffprobe se omitidas):
    # video_codec: h264      # codec do vídeo (ex: h264, hevc)
    # has_audio: false       # false = adiciona -an no ffmpeg; true = mantém áudio
    # width: 1920            # largura do vídeo em pixels
    # height: 1080           # altura do vídeo em pixels

  - id: quintal
    rtsp_url: rtsp://192.168.1.11:554/stream
    chunk_duration: 10m      # sobrescreve o default
    has_audio: false         # câmera sem microfone — pula detecção por ffprobe
