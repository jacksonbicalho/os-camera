# camera.yaml — arquivo de bootstrap mínimo
# Câmeras, motion e zonas de exclusão são gerenciados via UI/API (banco de dados).
# Este arquivo só precisa existir para o sistema iniciar pela primeira vez.

debug: false
timezone: America/Sao_Paulo       # env: CAMERA_TIMEZONE — fuso horário da instalação (padrão: UTC)

db_path: /data/camera.db           # caminho do banco SQLite (criado automaticamente)

log:
  output: stdout                   # stdout | file
  path:                            # diretório quando output: file

server:
  port: 8080
  segments_path: /tmp/hls          # diretório para segmentos HLS do streaming ao vivo
  hls_dvr_seconds: 0               # 0 = DVR desabilitado; >0 = janela DVR em segundos
  jwt_secret: ""                   # env: CAMERA_SERVER_JWT_SECRET — vazio = gerado aleatoriamente a cada boot

storage:
  path: /data/recordings           # env: CAMERA_STORAGE_PATH — diretório de gravações
  retention:
    with_motion_minutes: 10080     # 7 dias — 0 = nunca apaga gravações com movimento
    without_motion_minutes: 1440   # 1 dia  — 0 = desabilitado
  interval_minutes: 60             # intervalo entre limpezas (0 = 60 min)
  max_size_gb: 0                   # tamanho máximo em GB (0 = desabilitado)
  warn_percent: 90                 # % do max_size_gb para emitir aviso

admin:
  username: admin                  # usuário administrador criado na primeira inicialização
  password: changeme               # senha inicial — troca obrigatória no primeiro login
